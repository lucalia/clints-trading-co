@using ClintCardShop.Controllers
@using ClintCardShop.Data
@model ClintCardShop.Models.ModalPurchasesTabViewModel

@{
    var totalLinked = Model.CardPurchases.Count;

    // Aggregate: (Purchase, Variant) → count + location summary
    var grouped = Model.CardPurchases
        .GroupBy(x => (x.P.Id, x.Instance.Variant))
        .Select(g => (
            Purchase: g.First().P,
            Variant:  g.Key.Variant,
            Count:    g.Count(),
            Locations: g.Select(x => x.Instance.LocationId).Distinct()
                        .Select(lid => lid == CollectionDbContext.DefaultLocationId
                            ? "Collection"
                            : (Model.Locations.FirstOrDefault(l => l.Id == lid)?.Name ?? "?"))
                        .ToList()
        ))
        .OrderByDescending(x => x.Purchase.PurchasedAt)
        .ToList();
}

<div class="collection-section">
    <div class="collection-section-top" style="margin-bottom:.5rem">
        <span class="section-label" style="border:none;padding:0">Purchase History</span>
        <a href="/purchases" style="font-size:.75rem;color:var(--accent)">View all ↗</a>
    </div>

    @if (Model.TotalOwned > 0)
    {
        <div style="margin-bottom:.5rem">
            @if (totalLinked >= Model.TotalOwned)
            {
                <span class="reconcile-badge reconcile-ok">&#10003; All @Model.TotalOwned copies accounted for</span>
            }
            else if (totalLinked > 0)
            {
                <span class="reconcile-badge reconcile-partial">@totalLinked / @Model.TotalOwned copies linked (@(Model.TotalOwned - totalLinked) unlinked)</span>
            }
            else
            {
                <span class="reconcile-badge reconcile-none">@Model.TotalOwned copies — no purchase record</span>
            }
        </div>
    }

    @if (!grouped.Any())
    {
        <div class="loc-empty" style="padding:.5rem 0;text-align:left;font-size:.82rem">Not linked to any purchase yet.</div>
    }
    else
    {
        <div class="loc-assignments">
            @foreach (var row in grouped)
            {
                var perCard = row.Purchase.Quantity > 0 ? row.Purchase.TotalCost / row.Purchase.Quantity : 0;
                <div class="loc-assignment-row" style="align-items:flex-start">
                    <div style="min-width:0;flex:1">
                        <div style="font-weight:600;font-size:.82rem">
                            @row.Purchase.PurchasedAt.ToString("MMM d, yyyy") &mdash; @row.Purchase.Source
                        </div>
                        <div style="font-size:.75rem;color:var(--text2)">@row.Purchase.Description</div>
                        <div style="font-size:.72rem;color:var(--accent2);margin-top:.1rem">
                            $@perCard.ToString("F3") lot avg
                        </div>
                        <div style="font-size:.7rem;color:var(--text2)">@string.Join(", ", row.Locations)</div>
                    </div>
                    <div style="display:flex;align-items:center;gap:.3rem;flex-shrink:0">
                        <span class="variant-chip">@PartialsController.VariantShort(row.Variant) &#215;@row.Count</span>
                        @if (!string.IsNullOrWhiteSpace(row.Purchase.ReceiptUrl))
                        {
                            <a href="@row.Purchase.ReceiptUrl" target="_blank" rel="noopener"
                               class="purchase-receipt-link" style="font-size:.72rem">↗</a>
                        }
                    </div>
                </div>
            }
        </div>
    }

    <button class="btn-edit" style="margin-top:.5rem;width:100%"
            hx-get="/partials/modal-tab/@Model.CardId/purchases/link-form"
            hx-target="#modal-tab-content"
            hx-swap="innerHTML">+ Link to a Purchase</button>
</div>
