@using ClintCardShop.Data
@model Purchase

<form hx-post="/partials/purchase/@Model.Id/save"
      hx-target="#purchase-info"
      hx-swap="innerHTML"
      class="purchase-form">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id" />
    <div class="purchase-form-row">
        <label class="configure-label" style="flex:1">
            Date <input class="loc-input" type="date" name="PurchasedAt" value="@Model.PurchasedAt.ToString("yyyy-MM-dd")" />
        </label>
        <label class="configure-label" style="flex:2">
            Source <input class="loc-input" type="text" name="Source" value="@Model.Source" maxlength="100" />
        </label>
        <label class="configure-label">
            Type
            <select class="loc-select" name="Type">
                @foreach (var t in new[] { "Lot", "Pack", "Single", "Bundle", "Other" })
                {
                    <option value="@t" selected="@(Model.Type == t ? "selected" : null)">@t</option>
                }
            </select>
        </label>
    </div>
    <div class="purchase-form-row">
        <label class="configure-label" style="flex:1">
            Description <input class="loc-input" type="text" name="Description" value="@Model.Description" maxlength="200" />
        </label>
    </div>
    <div class="purchase-form-row">
        <label class="configure-label">
            Total Cost <input class="loc-input" type="number" min="0" step="0.01" style="width:110px" name="TotalCost" value="@Model.TotalCost" />
        </label>
        <label class="configure-label">
            Qty <input class="loc-input" type="number" min="1" style="width:90px" name="Quantity" value="@Model.Quantity" />
        </label>
    </div>
    <div class="purchase-form-row">
        <label class="configure-label" style="flex:1">
            Receipt URL <input class="loc-input" type="url" name="ReceiptUrl" value="@Model.ReceiptUrl" maxlength="500" />
        </label>
    </div>
    <div class="purchase-form-row">
        <label class="configure-label" style="flex:1">
            Notes <textarea class="loc-input" name="Notes" rows="2" maxlength="500">@Model.Notes</textarea>
        </label>
    </div>
    <div style="display:flex;gap:.5rem;margin-top:.25rem">
        <button type="submit" class="btn-save">Save</button>
        <button type="button" class="btn-cancel"
                hx-get="/partials/purchase/@Model.Id/cancel"
                hx-target="#purchase-info"
                hx-swap="innerHTML">Cancel</button>
    </div>
</form>
