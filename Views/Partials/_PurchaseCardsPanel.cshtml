@using ClintCardShop.Models
@model PurchaseCardsPanelViewModel

@{
    var linked     = Model.LinkedVariantCounts.Values.Sum();
    var reconciled = linked >= Model.Purchase.Quantity;
    var remaining  = Model.Purchase.Quantity - linked;
    var unlinkUrl  = "/partials/purchase/" + Model.Purchase.Id + "/unlink";
}

<div class="location-cards-panel">
    <div class="location-cards-panel-header">
        <span class="location-cards-panel-title">
            Linked Cards
            @if (Model.Purchase.Quantity > 0)
            {
                <span style="color:var(--text2);font-size:.8rem;margin-left:.5rem">
                    (@linked / @Model.Purchase.Quantity linked@(remaining > 0 ? $", {remaining} remaining" : ""))
                </span>
            }
        </span>
        @if (!reconciled)
        {
            <button class="btn-add" style="padding:.3rem .75rem;font-size:.8rem"
                    hx-get="/partials/add-card/sets?context=purchase&ctxId=@Model.Purchase.Id"
                    hx-target="#add-card-panel"
                    hx-swap="innerHTML">+ Link Card</button>
        }
    </div>

    <div id="add-card-panel"></div>

    @if (Model.CardBriefs.Count == 0)
    {
        <div class="loc-empty">No cards linked yet. Click <strong>+ Link Card</strong> to get started.</div>
    }
    else
    {
        <div class="location-cards-summary">
            @Model.CardBriefs.Count unique card@(Model.CardBriefs.Count == 1 ? "" : "s")
        </div>
        <partial name="~/Views/Partials/_DetailCardGrid.cshtml"
                 model="new DetailCardGridViewModel(
                     Model.CardBriefs.Select(x => x.Card).ToList(),
                     Model.LinkedVariantCounts, null, unlinkUrl)" />
    }
</div>
