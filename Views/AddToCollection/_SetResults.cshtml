@using ClintCardShop.Models
@model AddToCollectionSetsViewModel

@{
    var pre = (string.IsNullOrEmpty(Model.PreListId) ? "" : $"&preListId={Uri.EscapeDataString(Model.PreListId)}")
            + (string.IsNullOrEmpty(Model.PrePurchaseId) ? "" : $"&prePurchaseId={Uri.EscapeDataString(Model.PrePurchaseId)}");
}

@foreach (var set in Model.Sets.Take(80))
{
    <button type="button" class="set-pick-item"
            hx-get="/partials/add-to-collection/cards?setId=@Uri.EscapeDataString(set.Id)@pre"
            hx-target="#add-collection-host"
            hx-swap="innerHTML">
        @if (set.Logo is not null)
        {
            <img class="set-pick-logo" src="@(set.Logo + ".webp")" alt="" onerror="this.style.display='none'" />
        }
        <span>@set.Name</span>
        <span class="set-count" style="margin-left:auto;font-size:.75rem;color:var(--text2)">@(set.CardCount?.Total ?? 0) cards</span>
        @if (Model.OwnedSetIds.Contains(set.Id))
        {
            <span class="list-shared-badge">Owned</span>
        }
    </button>
}
@if (!Model.Sets.Any())
{
    <div class="loc-empty" style="padding:.75rem 0">No sets match your search.</div>
}
