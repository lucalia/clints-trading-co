@page "/locations"
@attribute [Authorize]
@using ClintCardShop.Data
@inject LocationService LocationSvc
@inject CollectionService Collection

<PageTitle>Locations &mdash; Clint's Trading Co.</PageTitle>

<div class="locations-page">
    <h2 class="page-title">Storage Locations</h2>

    <div class="add-location-form">
        <h3 class="form-title">Add Location</h3>
        <div class="form-row">
            <input class="loc-input" type="text" placeholder="Name (e.g. Main Binder)"
                   @bind="_newName" @bind:event="oninput" maxlength="60" />
            <button class="btn-add" @onclick="AddLocationAsync"
                    disabled="@(string.IsNullOrWhiteSpace(_newName))">
                + Add
            </button>
        </div>
        @if (_addError is not null)
        {
            <div class="form-error">@_addError</div>
        }
    </div>

    @if (_loading)
    {
        <div class="loc-loading">Loading&hellip;</div>
    }
    else
    {
        <div class="location-grid">
            <div class="location-card">
                <div class="location-card-header">
                    <a href="/locations/0" class="list-name-link">Collection</a>
                    <span class="list-shared-badge">Default</span>
                </div>
                <div class="location-card-footer">
                    <span class="location-count">@(_cardCounts.TryGetValue(CollectionDbContext.DefaultLocationId, out var defCnt) ? defCnt : 0) copies stored</span>
                </div>
            </div>
            @foreach (var loc in _locations)
            {
                <div class="location-card">
                    <div class="location-card-header">
                        @if (_editingId == loc.Id)
                        {
                            <input class="loc-input inline" @bind="_editName" @bind:event="oninput" maxlength="60" />
                        }
                        else
                        {
                            <a href="/locations/@loc.Id" class="list-name-link">@loc.Name</a>
                        }
                    </div>
                    <div class="location-card-footer">
                        <span class="location-count">@(_cardCounts.TryGetValue(loc.Id, out var locCnt) ? locCnt : 0) copies stored</span>
                        <div class="location-actions">
                            @if (_editingId == loc.Id)
                            {
                                <button class="btn-save" @onclick="() => SaveEditAsync(loc.Id)">Save</button>
                                <button class="btn-cancel" @onclick="CancelEdit">Cancel</button>
                            }
                            else
                            {
                                <button class="btn-edit" @onclick="() => StartEdit(loc)">Edit</button>
                                <button class="btn-delete" @onclick="() => DeleteAsync(loc.Id)">Delete</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Location> _locations = new();
    private Dictionary<string, int> _cardCounts = new();
    private bool _loading = true;
    private string _newName = "";
    private string? _addError;
    private string _editingId = "";
    private string _editName = "";

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        _loading = false;
    }

    private async Task RefreshAsync()
    {
        var locsTask   = LocationSvc.GetAllAsync();
        var countsTask = Collection.GetCountsPerLocationAsync();
        await Task.WhenAll(locsTask, countsTask);
        _locations  = locsTask.Result;
        _cardCounts = countsTask.Result;
    }

    private async Task AddLocationAsync()
    {
        _addError = null;
        if (string.IsNullOrWhiteSpace(_newName)) return;
        if (_locations.Any(l => l.Name.Equals(_newName.Trim(), StringComparison.OrdinalIgnoreCase)))
        {
            _addError = "A location with that name already exists.";
            return;
        }
        await LocationSvc.AddAsync(_newName);
        _newName = "";
        await RefreshAsync();
    }

    private void StartEdit(Location loc) { _editingId = loc.Id; _editName = loc.Name; }

    private async Task SaveEditAsync(string id)
    {
        if (string.IsNullOrWhiteSpace(_editName)) return;
        await LocationSvc.UpdateAsync(id, _editName);
        _editingId = "";
        await RefreshAsync();
    }

    private void CancelEdit() => _editingId = "";

    private async Task DeleteAsync(string id)
    {
        await LocationSvc.DeleteAsync(id);
        await RefreshAsync();
    }
}
