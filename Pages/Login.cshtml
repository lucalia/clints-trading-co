@page "/login"
@model ClintCardShop.Pages.LoginModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In &mdash; Clint's Trading Co.</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: #0d1117;
            color: #e6edf3;
            font-family: 'Segoe UI', system-ui, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: #161b22;
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 14px;
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 360px;
            box-shadow: 0 8px 32px rgba(0,0,0,.6);
        }
        .login-title {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: .25rem;
        }
        .login-sub {
            font-size: .82rem;
            color: #8b949e;
            margin-bottom: 1.75rem;
        }
        label {
            display: block;
            font-size: .8rem;
            font-weight: 600;
            color: #8b949e;
            text-transform: uppercase;
            letter-spacing: .05em;
            margin-bottom: .4rem;
        }
        input {
            width: 100%;
            padding: .6rem .9rem;
            background: #21262d;
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 8px;
            color: #e6edf3;
            font-size: .95rem;
            outline: none;
            margin-bottom: 1.1rem;
            transition: border-color .2s;
        }
        input:focus { border-color: #58a6ff; }
        button {
            width: 100%;
            padding: .65rem;
            background: #58a6ff;
            border: none;
            border-radius: 8px;
            color: #0d1117;
            font-weight: 700;
            font-size: .95rem;
            cursor: pointer;
            transition: opacity .15s;
        }
        button:hover { opacity: .85; }
        .error {
            background: rgba(248,81,73,.15);
            border: 1px solid rgba(248,81,73,.4);
            border-radius: 8px;
            color: #f85149;
            font-size: .85rem;
            padding: .6rem .9rem;
            margin-bottom: 1rem;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <img src="/img/logo.png" alt="Clint's Trading Co." style="width:220px;display:block;margin:0 auto 1.5rem;" />
        <div class="login-sub" style="text-align:center;margin-bottom:1.5rem">Sign in to continue</div>

        @if (Model.Error is not null)
        {
            <div class="error">@Model.Error</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <label for="username">Email</label>
            <input id="username" name="username" type="email" autocomplete="username"
                   value="@Model.Username" required autofocus />

            <label for="password">Password</label>
            <input id="password" name="password" type="password" autocomplete="current-password" required />

            <button type="submit">Sign in</button>
        </form>
    </div>
</body>
</html>
