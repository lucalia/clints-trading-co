@page
@model ClintCardShop.Pages.IndexModel
@using ClintCardShop.Models
@{
    ViewData["Title"] = "All Sets";
}

<div class="sets-page">
    <h2 class="page-title">All Sets</h2>

    @if (Model.Error is not null)
    {
        <div class="error-banner"><strong>Failed to load sets:</strong> @Model.Error</div>
    }
    else
    {
        <div class="collection-controls">
            <div class="controls-inner">
                <span class="stat-chip" id="sets-count">@Model.Groups.Sum(g => g.Sets.Count) / @Model.TotalSets sets</span>
                <input class="search-input"
                       type="text"
                       name="q"
                       placeholder="Search sets&hellip;"
                       autocomplete="off"
                       hx-get="/partials/sets"
                       hx-trigger="input delay:300ms"
                       hx-target="#sets-container"
                       hx-swap="innerHTML"
                       hx-include="this" />
            </div>
        </div>

        <div id="sets-container">
            @foreach (var (serie, sets) in Model.Groups)
            {
                <div class="series-section">
                    <h3 class="series-header">@SetGrouping.DisplayName(serie)</h3>
                    <div class="sets-grid">
                        @foreach (var set in sets)
                        {
                            <a class="set-card" href="/set/@set.Id">
                                @if (set.Logo is not null)
                                {
                                    <img class="set-logo" src="@(set.Logo + ".webp")" alt="@set.Name"
                                         loading="lazy"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                    <div class="set-logo-placeholder" style="display:none">@set.Name</div>
                                }
                                else
                                {
                                    <div class="set-logo-placeholder">@set.Name</div>
                                }
                                <div class="set-info">
                                    <span class="set-name">@set.Name</span>
                                    <span class="set-count">@(set.CardCount?.Total ?? 0) cards &bull; @set.Id</span>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }
            @if (Model.Groups.Count == 0)
            {
                <div class="loc-empty">No sets match your search.</div>
            }
        </div>
    }
</div>
