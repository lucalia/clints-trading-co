<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")Clint's Trading Co.</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/favicon.png" />
</head>
<body>
<div class="app-shell">
    <header class="app-header">
        <div class="header-content">
            <div class="header-brand">
                <img src="/img/logo.png" class="brand-logo" alt="Clint's Trading Co." />
                <span class="brand-title">Clint's Trading Co.</span>
            </div>
            <nav class="header-nav">
                <a class="nav-link" href="/login">Sign in</a>
            </nav>
        </div>
    </header>
    <main class="app-main">
        <div id="modal-host"></div>
        @RenderBody()
    </main>
    <footer class="app-footer">
        Clint's Trading Co. &mdash; Card data via <a href="https://tcgdex.dev" target="_blank" rel="noopener">TCGDex</a>
    </footer>
</div>
<script src="https://unpkg.com/htmx.org@2.0.4" crossorigin="anonymous"></script>
<script src="~/js/app.js" asp-append-version="true"></script>
</body>
</html>
